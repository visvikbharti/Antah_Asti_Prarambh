# RULE 6: FoldX stability calculations (via array jobs)
# =============================================================================

rule foldx_generate_jobs:
    """Generate SLURM array job scripts for FoldX calculations."""
    input:
        checkpoint = os.path.join(STRUCTURES, "download_checkpoint.json"),
    output:
        slurm_script = os.path.join(FOLDX_DIR, "foldx_array.slurm"),
    params:
        script = os.path.join(SCRIPTS, "run_foldx.py"),
        config = os.path.join(SCRIPTS, "config.yaml"),
    threads: 1
    resources:
        mem_mb   = 2000,
        runtime  = "00:10:00",
    log:
        os.path.join(RESULTS, "logs/foldx_generate.log"),
    shell:
        """
        python {params.script} \
            --config {params.config} \
            --generate-slurm \
            2>&1 | tee {log}
        """


rule foldx_run:
    """
    Run FoldX stability calculations.
    In practice, submit the generated SLURM array job separately.
    This rule runs serially as a fallback (or for small batches).
    """
    input:
        checkpoint = os.path.join(STRUCTURES, "download_checkpoint.json"),
    output:
        results = os.path.join(FOLDX_DIR, "foldx_stability_all.tsv"),
    params:
        script = os.path.join(SCRIPTS, "run_foldx.py"),
        config = os.path.join(SCRIPTS, "config.yaml"),
    threads: 1
    resources:
        mem_mb   = 4000,
        runtime  = "48:00:00",
        partition = config.get("slurm", {}).get("partition", "normal"),
    log:
        os.path.join(RESULTS, "logs/foldx_run.log"),
    shell:
        """
        # NOTE: For full-scale runs, use the SLURM array job instead:
        #   sbatch {FOLDX_DIR}/foldx_array.slurm
        # This serial fallback is for testing or small organisms.

        python {params.script} \
            --config {params.config} \
            --serial \
            2>&1 | tee {log}
        """


