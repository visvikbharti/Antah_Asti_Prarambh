# =============================================================================
# RULE 1: Download AlphaFold full proteomes
# =============================================================================

rule download_alphafold:
    """Download full AlphaFold structures for E. coli and Human proteomes."""
    output:
        checkpoint = os.path.join(STRUCTURES, "download_checkpoint.json"),
        index      = os.path.join(STRUCTURES, "structure_index_full.tsv"),
    params:
        config = os.path.join(SCRIPTS, "config.yaml"),
        script = os.path.join(SCRIPTS, "download_alphafold_full.py"),
    threads: 1
    resources:
        mem_mb   = 4000,
        runtime  = "12:00:00",
        partition = config.get("slurm", {}).get("partition", "normal"),
    log:
        os.path.join(RESULTS, "logs/download_alphafold.log"),
    shell:
        """
        python {params.script} \
            --config {params.config} \
            --organism both \
            --workers {config[alphafold][download_workers]} \
            2>&1 | tee {log}
        """


