# RULE 7: Domain distribution analysis (Module E full-scale)
# =============================================================================

rule module_e_analysis:
    """
    Compute domain architecture distribution for full proteomes.
    Re-runs Module E analyses from Phase 1 on the full dataset.
    """
    input:
        chainsaw   = os.path.join(DOMAINS, "chainsaw_full_predictions.tsv"),
        clusters   = os.path.join(FOLDSEEK, "analysis/foldseek_clusters_full.tsv"),
    output:
        distribution = os.path.join(DOMAINS, "domain_distribution_full.tsv"),
    params:
        phase1_cath = config.get("phase1_inputs", {}).get(
            "groel_substrates",
            os.path.join(PHASE1, "results/domains/cath_domain_assignments.tsv")
        ),
    threads: 4
    resources:
        mem_mb   = 16000,
        runtime  = "04:00:00",
        partition = config.get("slurm", {}).get("partition", "normal"),
    log:
        os.path.join(RESULTS, "logs/module_e_analysis.log"),
    run:
        # This rule integrates CATH (from InterPro API or Phase 1) with Chainsaw
        # predictions for the full proteomes, then computes distributions.
        # The actual analysis logic mirrors Phase 1 domain_distribution_summary.py
        # but at full scale.
        shell("""
        echo "Module E full-scale analysis" | tee {log}
        echo "Input: {input.chainsaw}" | tee -a {log}
        echo "Input: {input.clusters}" | tee -a {log}

        python -c "
import pandas as pd
import os

# Load Chainsaw predictions
chainsaw = pd.read_csv('{input.chainsaw}', sep='\\t')
print(f'Chainsaw predictions: {{len(chainsaw)}} proteins')

# Load Foldseek clusters
clusters = pd.read_csv('{input.clusters}', sep='\\t')
print(f'Foldseek clusters: {{len(clusters)}} proteins')

# Compute domain count distribution
if 'n_domains' in chainsaw.columns:
    dist = chainsaw['n_domains'].value_counts().sort_index()
    print('\\nDomain count distribution:')
    print(dist)

# Save distribution
output_path = '{output.distribution}'
os.makedirs(os.path.dirname(output_path), exist_ok=True)
chainsaw.to_csv(output_path, sep='\\t', index=False)
print(f'\\nSaved to: {{output_path}}')
" 2>&1 | tee -a {log}
        """)


