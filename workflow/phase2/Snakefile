# =============================================================================
# RULE 5: Chainsaw domain assignment
# =============================================================================

rule chainsaw_domains:
    """
    Run Chainsaw domain boundary prediction on all proteins.
    Processes proteins that lack CATH domain assignments.
    For Phase 2, this runs on the full proteomes.
    """
    input:
        checkpoint = os.path.join(STRUCTURES, "download_checkpoint.json"),
    output:
        predictions = os.path.join(DOMAINS, "chainsaw_full_predictions.tsv"),
    params:
        chainsaw_dir = config.get("chainsaw", {}).get("install_dir", "/tmp/chainsaw"),
        batch_size   = config.get("chainsaw", {}).get("batch_size", 500),
    threads: 4
    resources:
        mem_mb   = 16000,
        runtime  = "08:00:00",
        partition = config.get("slurm", {}).get("partition", "normal"),
    log:
        os.path.join(RESULTS, "logs/chainsaw_domains.log"),
    run:
        import subprocess, tempfile, glob as globmod

        # Collect all CIF files from both organisms
        cif_files = []
        for struct_dir in [AF_ECOLI, AF_HUMAN]:
            if os.path.isdir(struct_dir):
                cif_files.extend(globmod.glob(os.path.join(struct_dir, "AF-*-F1-model_v*.cif")))

        shell(f"echo 'Processing {{len(cif_files)}} structures with Chainsaw' | tee {{log}}")

        # Process in batches
        batch_size = int(params.batch_size)
        all_results = []

        for batch_start in range(0, len(cif_files), batch_size):
            batch = cif_files[batch_start:batch_start + batch_size]
            batch_id = batch_start // batch_size

            with tempfile.TemporaryDirectory(prefix=f"chainsaw_batch_{batch_id}_") as tmpdir:
                # Symlink batch CIFs
                for cif in batch:
                    dst = os.path.join(tmpdir, os.path.basename(cif))
                    if not os.path.exists(dst):
                        os.symlink(cif, dst)

                batch_out = os.path.join(DOMAINS, f"chainsaw_batch_{batch_id:04d}.tsv")

                cmd = [
                    config.get("chainsaw", {}).get("python", "python3"),
                    os.path.join(params.chainsaw_dir, "get_predictions.py"),
                    "--structure_directory", tmpdir,
                    "--output", batch_out,
                    "--use_first_chain",
                ]

                try:
                    subprocess.run(cmd, capture_output=True, text=True,
                                   cwd=params.chainsaw_dir, timeout=7200)
                    if os.path.exists(batch_out):
                        all_results.append(batch_out)
                except Exception as e:
                    shell(f"echo 'Batch {batch_id} failed: {e}' >> {{log}}")

        # Merge batch results
        with open(output.predictions, "w") as fout:
            header_written = False
            for result_file in all_results:
                with open(result_file) as fin:
                    for i, line in enumerate(fin):
                        if i == 0:
                            if not header_written:
                                fout.write(line)
                                header_written = True
                        else:
                            fout.write(line)

        shell(f"echo 'Chainsaw complete: merged {{len(all_results)}} batches' >> {{log}}")


