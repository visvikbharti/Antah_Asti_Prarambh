# =============================================================================
# Antah Asti Prarambh — Phase 2 Snakemake Workflow
# =============================================================================
#
# Full-scale analysis of E. coli K-12 (4,403) + Human (20,416) proteomes.
# Designed for HPC execution with SLURM.
#
# Dependency graph:
#
#   download_alphafold
#          |
#    +-----+-----+-------------------+
#    |           |                   |
#    v           v                   v
#   foldseek  chainsaw_domains    foldx_stability
#    |           |                   |
#    v           v                   v
#   foldseek  domain_metrics      stability_metrics
#   _analyze     |                   |
#    |           +---+---+-----------+
#    |               |   |
#    v               v   v
#   module_e    module_f_analysis
#    |               |
#    +---+---+---+---+
#        |       |
#        v       v
#   module_g  module_h_stats
#                |
#                v
#           module_i_figures
#
# Usage:
#   # Dry run (see what would execute):
#   snakemake -n --configfile config.yaml
#
#   # Local execution:
#   snakemake --configfile config.yaml --cores 8
#
#   # SLURM cluster execution:
#   snakemake --configfile config.yaml \
#     --profile slurm \
#     --jobs 50 \
#     --latency-wait 60
#
#   # Or with explicit SLURM params:
#   snakemake --configfile config.yaml \
#     --cluster "sbatch --partition={resources.partition} \
#                --mem={resources.mem_mb}M \
#                --cpus-per-task={threads} \
#                --time={resources.runtime}" \
#     --jobs 50 \
#     --latency-wait 60
#
# =============================================================================

import os

# -- Load configuration -------------------------------------------------------
configfile: "config.yaml"

PROJECT = config["project_dir"]
PHASE1  = config.get("phase1_dir", PROJECT + "/phase1")
RESULTS = config["results"]["base_dir"]
DATA    = config["data"]

# Resolve path templates
def resolve_path(p):
    return p.replace("{project_dir}", PROJECT).replace("{phase1_dir}", PHASE1)

# Resolve all paths in config
for section in ["data", "results", "phase1_inputs"]:
    if section in config:
        for k, v in config[section].items():
            if isinstance(v, str):
                config[section][k] = resolve_path(v)

# -- Convenience paths ---------------------------------------------------------
AF_ECOLI   = config["data"]["alphafold_ecoli_dir"]
AF_HUMAN   = config["data"]["alphafold_human_dir"]
FOLDSEEK   = config["results"]["foldseek_dir"]
FOLDX_DIR  = config["results"]["foldx_dir"]
DOMAINS    = config["results"]["domains_dir"]
STATS      = config["results"]["stats_dir"]
FIGURES    = config["results"]["figures_dir"]
STRUCTURES = config["results"]["structures_dir"]

# -- Script directory ----------------------------------------------------------
SCRIPTS    = os.path.dirname(workflow.snakefile)
P1_SCRIPTS = os.path.join(PHASE1, "workflow/scripts")

# -- Module toggles -----------------------------------------------------------
RUN = config.get("run_modules", {})


