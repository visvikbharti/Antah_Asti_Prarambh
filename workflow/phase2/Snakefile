rule clean_temp:
    """Remove temporary Foldseek and FoldX working files."""
    shell:
        """
        echo "Cleaning temporary files..."
        rm -rf {FOLDSEEK}/databases/combined_structures
        rm -rf {config[foldseek][tmp_dir]}
        rm -rf {FOLDX_DIR}/work
        echo "Done."
        """


rule status:
    """Print pipeline status — which outputs exist."""
    run:
        targets = {
            "AlphaFold download": os.path.join(STRUCTURES, "download_checkpoint.json"),
            "Structure index": os.path.join(STRUCTURES, "structure_index_full.tsv"),
            "Foldseek clusters": os.path.join(FOLDSEEK, "analysis/foldseek_clusters_full.tsv"),
            "Chainsaw domains": os.path.join(DOMAINS, "chainsaw_full_predictions.tsv"),
            "FoldX stability": os.path.join(FOLDX_DIR, "foldx_stability_all.tsv"),
            "Domain distribution": os.path.join(DOMAINS, "domain_distribution_full.tsv"),
            "Stability comparisons": os.path.join(STATS, "stability_comparisons_full.tsv"),
            "Statistics report": os.path.join(STATS, "statistics_summary_full.txt"),
            "Figures": os.path.join(FIGURES, "phase2_figures_complete.flag"),
        }

        print("\n" + "=" * 60)
        print("  Phase 2 Pipeline Status")
        print("=" * 60)
        for name, path in targets.items():
            exists = os.path.exists(path)
            status = "DONE" if exists else "PENDING"
            size = ""
            if exists:
                s = os.path.getsize(path)
                if s > 1e9:
                    size = f" ({s/1e9:.1f} GB)"
                elif s > 1e6:
                    size = f" ({s/1e6:.1f} MB)"
                else:
                    size = f" ({s/1e3:.1f} KB)"
            print(f"  [{status:>7}] {name:30s}{size}")
        print("=" * 60)
