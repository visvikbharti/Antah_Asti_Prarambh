rule module_h_stats:
    """
    Run full comparative statistics with expanded dataset.
    Tests all pre-registered hypotheses from Phase 1 on full proteomes.
    """
    input:
        domains      = os.path.join(DOMAINS, "domain_distribution_full.tsv"),
        stability    = os.path.join(STATS, "stability_comparisons_full.tsv"),
        clusters     = os.path.join(FOLDSEEK, "analysis/foldseek_clusters_full.tsv"),
    output:
        report = os.path.join(STATS, "statistics_summary_full.txt"),
    params:
        groel     = config.get("phase1_inputs", {}).get("groel_substrates", ""),
        hsp60     = config.get("phase1_inputs", {}).get("hsp60_substrates", ""),
        homologs  = config.get("phase1_inputs", {}).get("homologs", ""),
    threads: 4
    resources:
        mem_mb   = 16000,
        runtime  = "04:00:00",
        partition = config.get("slurm", {}).get("partition", "normal"),
    log:
        os.path.join(RESULTS, "logs/module_h_stats.log"),
    run:
        # Full Module H analysis at scale
        # This mirrors module_h_comparative_stats.py but uses Phase 2 data
        shell("""
        echo "Module H full-scale statistics" | tee {log}

        python -c "
import pandas as pd
import os
from datetime import datetime

print('='*70)
print('Module H: Phase 2 Full-Scale Comparative Statistics')
print(f'Run date: {{datetime.now()}}')
print('='*70)

# Load Phase 2 results
domains = pd.read_csv('{input.domains}', sep='\\t')
stability = pd.read_csv('{input.stability}', sep='\\t')
clusters = pd.read_csv('{input.clusters}', sep='\\t')

print(f'\\nDomain data: {{len(domains)}} proteins')
print(f'Stability data: {{len(stability)}} proteins')
print(f'Cluster data: {{len(clusters)}} proteins')

# Load substrate lists from Phase 1
groel_path = '{params.groel}'
hsp60_path = '{params.hsp60}'

if os.path.exists(groel_path):
    groel = pd.read_csv(groel_path, sep='\\t')
    print(f'GroEL substrates: {{len(groel)}}')

if os.path.exists(hsp60_path):
    hsp60 = pd.read_csv(hsp60_path, sep='\\t')
    print(f'HSP60 substrates: {{len(hsp60)}}')

# [Statistical tests would be implemented here following the same
#  framework as module_h_comparative_stats.py but on Phase 2 data]
# Tests include:
#   - H2: Domain architecture enrichment (Fisher exact tests)
#   - H3: N-vs-C stability (Wilcoxon signed-rank, now with FoldX DeltaG)
#   - H4: MTS targeting statistics
#   - H5: Multiple testing correction (BH)

report_lines = [
    '='*70,
    'PHASE 2 STATISTICS SUMMARY',
    '='*70,
    '',
    f'Total proteins analyzed: {{len(domains)}}',
    f'Stability measurements: {{len(stability)}}',
    f'Structural clusters: {{clusters[\"cluster_id\"].nunique() if \"cluster_id\" in clusters.columns else \"N/A\"}}',
    '',
    'NOTE: Full statistical analysis requires running Module H script',
    'with Phase 2 data paths updated in module_h_comparative_stats.py.',
    '='*70,
]

output_path = '{output.report}'
os.makedirs(os.path.dirname(output_path), exist_ok=True)
with open(output_path, 'w') as f:
    f.write('\\n'.join(report_lines) + '\\n')

print('\\n'.join(report_lines))
print(f'\\nReport saved: {{output_path}}')
" 2>&1 | tee -a {log}
        """)


